PORT=3001
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://presight:presight@localhost:5432/presight
DATABASE_POOL_MAX=20
# Set to true when connecting to managed Postgres (e.g. RDS, Neon, Supabase)
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
SEED_USER_COUNT=5000
# Set to true to truncate and reseed when data already exists
SEED_FORCE=false
# Artificial delay (ms) for all /api routes — useful for testing loading UI
API_DELAY_MS=700
