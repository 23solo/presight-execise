{
  "name": "presight-assignment-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "node-pg-migrate up --migrations-dir migrations",
    "db:migrate:down": "node-pg-migrate down --migrations-dir migrations",
    "db:migrate:create": "node-pg-migrate create --migrations-dir migrations",
    "db:migrate:redo": "node-pg-migrate redo --migrations-dir migrations",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:force": "SEED_FORCE=true tsx src/db/seed.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "pg": "^8.16.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.15.4",
    "node-pg-migrate": "^7.9.1",
    "@faker-js/faker": "^9.9.0",
    "tsx": "^4.19.4",
    "typescript": "~6.0.2"
  }
}
